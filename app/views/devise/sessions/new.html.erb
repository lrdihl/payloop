<p class="login-box-msg"><%= t("auth.login.title") %></p>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="mb-3">
    <%= f.label :email, t("auth.login.email"), class: "form-label" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "form-control", placeholder: t("auth.login.email_placeholder") %>
  </div>

  <div class="mb-3">
    <%= f.label :password, t("auth.login.password"), class: "form-label" %>
    <%= f.password_field :password, autocomplete: "current-password",
          class: "form-control", placeholder: t("auth.login.password_placeholder") %>
  </div>

  <% if devise_mapping.rememberable? %>
    <div class="mb-3 form-check">
      <%= f.check_box :remember_me, class: "form-check-input" %>
      <%= f.label :remember_me, t("auth.login.remember_me"), class: "form-check-label" %>
    </div>
  <% end %>

  <div class="d-grid">
    <%= f.submit t("auth.login.submit"), class: "btn btn-primary" %>
  </div>
<% end %>

<p class="mt-3 text-center">
  <%= t("auth.login.no_account") %> <%= link_to t("auth.login.sign_up_link"), new_user_registration_path %>
</p>
