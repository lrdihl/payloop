<div class="app-content-header">
  <div class="container-fluid">
    <h3 class="mb-0"><%= t(".title") %></h3>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <%# Linha 1: Gráfico de faturamento + Card de assinaturas ativas %>
    <div class="row mb-4">

      <%# Gráfico de faturamento — 5 meses %>
      <div class="col-lg-8 col-12 mb-3 mb-lg-0">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="card-title mb-0">
              <i class="fa fa-chart-bar me-2 text-primary"></i>
              <%= t(".billing_chart.title") %>
            </h5>
          </div>
          <div class="card-body">
            <canvas id="billingChart" style="max-height: 260px;"></canvas>
          </div>
        </div>
      </div>

      <%# Card: assinaturas ativas %>
      <div class="col-lg-4 col-12">
        <div class="card h-100 text-center border-success">
          <div class="card-body d-flex flex-column justify-content-center align-items-center">
            <i class="fa fa-check-circle fa-3x text-success mb-3"></i>
            <h1 class="display-3 fw-bold text-success mb-1"><%= @active_count %></h1>
            <p class="text-muted mb-0"><%= t(".active_subscriptions.title") %></p>
          </div>
        </div>
      </div>

    </div>

    <%# Linha 2: Assinaturas com pagamento pendente (master-detail) %>
    <div class="card">
      <div class="card-header">
        <h5 class="card-title mb-0">
          <i class="fa fa-clock me-2 text-warning"></i>
          <%= t(".pending_section.title") %>
          <span class="badge bg-warning text-dark ms-2"><%= @pending_subscriptions.size %></span>
        </h5>
      </div>
      <div class="card-body p-0">
        <% if @pending_subscriptions.empty? %>
          <p class="text-muted text-center py-4 mb-0"><%= t(".pending_section.empty") %></p>
        <% else %>
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th style="width: 2rem;"></th>
                <th><%= t(".pending_section.columns.client") %></th>
                <th><%= t(".pending_section.columns.plan") %></th>
                <th><%= t(".pending_section.columns.due_date") %></th>
                <th class="text-end"><%= t(".pending_section.payments_columns.actions") %></th>
              </tr>
            </thead>
            <tbody>
              <% @pending_subscriptions.each do |sub| %>
                <%# Linha mestre %>
                <tr class="cursor-pointer"
                    data-bs-toggle="collapse"
                    data-bs-target="#payments-<%= sub.id %>"
                    style="cursor: pointer;">
                  <td class="text-center text-muted">
                    <i class="fa fa-chevron-right fa-xs toggle-icon" id="icon-<%= sub.id %>"></i>
                  </td>
                  <td><%= sub.user.email %></td>
                  <td><%= sub.plan.name %></td>
                  <td><%= l(sub.next_due_date) %></td>
                  <td class="text-end">
                    <%= button_to t(".pending_section.reprocess"),
                          charge_admin_subscription_path(sub),
                          method: :patch,
                          class: "btn btn-sm btn-warning",
                          data: { turbo_confirm: "Confirmar reprocessamento?" },
                          onclick: "event.stopPropagation();" %>
                  </td>
                </tr>

                <%# Linha detalhe: pagamentos da assinatura %>
                <tr class="collapse" id="payments-<%= sub.id %>">
                  <td colspan="5" class="p-0 bg-light">
                    <div class="px-4 py-3">
                      <% sorted_payments = sub.payments.sort_by(&:created_at).reverse %>
                      <% if sorted_payments.empty? %>
                        <p class="text-muted mb-0 small">Nenhum pagamento registrado.</p>
                      <% else %>
                        <table class="table table-sm table-bordered mb-0">
                          <thead class="table-secondary">
                            <tr>
                              <th><%= t(".pending_section.payments_columns.id") %></th>
                              <th><%= t(".pending_section.payments_columns.date") %></th>
                              <th><%= t(".pending_section.payments_columns.amount") %></th>
                              <th><%= t(".pending_section.payments_columns.method") %></th>
                              <th><%= t(".pending_section.payments_columns.attempt") %></th>
                              <th><%= t(".pending_section.payments_columns.status") %></th>
                            </tr>
                          </thead>
                          <tbody>
                            <% sorted_payments.each do |payment| %>
                              <tr>
                                <td><%= payment.id %></td>
                                <td><%= l(payment.created_at) %></td>
                                <td><%= payment.amount %></td>
                                <td><%= payment_method_name(payment.payment_method) %></td>
                                <td class="text-center"><%= payment.attempt_number %></td>
                                <td>
                                  <span class="badge <%= payment_status_badge_class(payment.status) %>">
                                    <%= t("shared.payment_statuses.#{payment.status}") %>
                                  </span>
                                </td>
                              </tr>
                            <% end %>
                          </tbody>
                        </table>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    </div>

  </div>
</div>

<%= content_for :scripts do %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
  <script>
    const labels  = <%= raw @billing_months.map { |m| m[:label] }.to_json %>;
    const data    = <%= raw @billing_months.map { |m| (m[:amount_cents] / 100.0).round(2) }.to_json %>;

    new Chart(document.getElementById('billingChart'), {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: 'Faturamento (R$)',
          data: data,
          backgroundColor: 'rgba(13, 110, 253, 0.75)',
          borderColor: 'rgba(13, 110, 253, 1)',
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: {
              callback: value => 'R$ ' + value.toLocaleString('pt-BR', { minimumFractionDigits: 2 })
            }
          }
        }
      }
    });

    // Rotaciona o ícone ao expandir/colapsar
    document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(row => {
      const targetId = row.getAttribute('data-bs-target').replace('#', '');
      const icon     = document.getElementById('icon-' + targetId.replace('payments-', ''));
      const collapse = document.getElementById(targetId);
      if (!collapse || !icon) return;
      collapse.addEventListener('show.bs.collapse',  () => icon.classList.replace('fa-chevron-right', 'fa-chevron-down'));
      collapse.addEventListener('hide.bs.collapse',  () => icon.classList.replace('fa-chevron-down',  'fa-chevron-right'));
    });
  </script>
<% end %>
