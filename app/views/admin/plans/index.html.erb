<div class="app-content-header">
  <div class="container-fluid">
    <h3 class="mb-0"><%= t(".title") %></h3>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <%= link_to t(".new"), new_admin_plan_path, class: "btn btn-primary mb-3" %>

    <div class="card">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th><%= t(".columns.id") %></th>
              <th><%= t(".columns.name") %></th>
              <th><%= t(".columns.price") %></th>
              <th><%= t(".columns.recurrence") %></th>
              <th><%= t(".columns.status") %></th>
              <th><%= t(".columns.actions") %></th>
            </tr>
          </thead>
          <tbody>
            <% @plans.each do |plan| %>
              <tr>
                <td><%= plan.id %></td>
                <td><%= plan.name %></td>
                <td><%= plan.price %></td>
                <td><%= format_period(plan.interval_count, plan.interval_type) %></td>
                <td>
                  <span class="badge bg-<%= plan.active? ? 'success' : 'secondary' %>">
                    <%= plan.active? ? t(".status.active") : t(".status.inactive") %>
                  </span>
                </td>
                <td>
                  <%= link_to t("shared.actions.edit"), edit_admin_plan_path(plan), class: "btn btn-sm btn-outline-warning" %>
                  <%= button_to t("shared.actions.remove"), admin_plan_path(plan), method: :delete,
                        class: "btn btn-sm btn-outline-danger",
                        data: { turbo_confirm: t("shared.actions.confirm_remove") } %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
