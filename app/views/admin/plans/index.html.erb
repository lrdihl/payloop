<% content_for :page_title, t(".title") %>

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="card-title"><%= t(".table_title") %></h3>
    <%= link_to t(".new"), new_admin_plan_path, class: "btn btn-primary btn-sm" %>
  </div>
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th><%= t(".columns.id") %></th>
          <th><%= t(".columns.name") %></th>
          <th><%= t(".columns.price") %></th>
          <th><%= t(".columns.recurrence") %></th>
          <th><%= t(".columns.status") %></th>
          <th><%= t(".columns.actions") %></th>
        </tr>
      </thead>
      <tbody>
        <% @plans.each do |plan| %>
          <tr>
            <td><%= plan.id %></td>
            <td><%= plan.name %></td>
            <td><%= number_to_currency(plan.price_cents / 100.0, unit: plan.currency == "BRL" ? "R$" : "$") %></td>
            <td><%= plan.interval_count %>x <%= plan.interval_type %></td>
            <td>
              <span class="badge bg-<%= plan.active? ? 'success' : 'secondary' %>">
                <%= plan.active? ? t(".status.active") : t(".status.inactive") %>
              </span>
            </td>
            <td>
              <%= link_to t("shared.actions.edit"), edit_admin_plan_path(plan), class: "btn btn-sm btn-outline-warning" %>
              <%= button_to t("shared.actions.remove"), admin_plan_path(plan), method: :delete,
                    class: "btn btn-sm btn-outline-danger",
                    data: { turbo_confirm: t("shared.actions.confirm_remove") } %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
