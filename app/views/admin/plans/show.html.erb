<% content_for :page_title, t(".title", id: @plan.id) %>

<div class="card">
  <div class="card-header">
    <h3 class="card-title"><%= @plan.name %></h3>
    <div class="card-tools">
      <%= link_to t("shared.actions.edit"), edit_admin_plan_path(@plan), class: "btn btn-sm btn-warning" %>
      <%= link_to t("shared.actions.back"), admin_plans_path, class: "btn btn-sm btn-secondary" %>
    </div>
  </div>
  <div class="card-body">
    <dl class="row">
      <dt class="col-sm-4"><%= t(".fields.id") %></dt>
      <dd class="col-sm-8"><%= @plan.id %></dd>

      <dt class="col-sm-4"><%= t(".fields.name") %></dt>
      <dd class="col-sm-8"><%= @plan.name %></dd>

      <dt class="col-sm-4"><%= t(".fields.description") %></dt>
      <dd class="col-sm-8"><%= @plan.description || "—" %></dd>

      <dt class="col-sm-4"><%= t(".fields.price") %></dt>
      <dd class="col-sm-8"><%= @plan.price %></dd>

      <dt class="col-sm-4"><%= t(".fields.recurrence") %></dt>
      <dd class="col-sm-8"><%= format_period(@plan.interval_count, @plan.interval_type) %></dd>

      <dt class="col-sm-4"><%= t(".fields.status") %></dt>
      <dd class="col-sm-8">
        <span class="badge bg-<%= @plan.active? ? 'success' : 'secondary' %>">
          <%= @plan.active? ? t("admin.plans.index.status.active") : t("admin.plans.index.status.inactive") %>
        </span>
      </dd>
    </dl>
  </div>
</div>
