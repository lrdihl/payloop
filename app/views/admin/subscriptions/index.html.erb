<div class="app-content-header">
  <div class="container-fluid">
    <h3 class="mb-0"><%= t(".title") %></h3>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <%= link_to t(".new"), new_admin_subscription_path, class: "btn btn-primary mb-3" %>

    <div class="card">
      <div class="card-body p-0">
        <table class="table table-striped mb-0">
          <thead>
            <tr>
              <th><%= t(".columns.id") %></th>
              <th><%= t(".columns.client") %></th>
              <th><%= t(".columns.plan") %></th>
              <th><%= t(".columns.status") %></th>
              <th><%= t(".columns.next_due") %></th>
              <th><%= t(".columns.closed_at") %></th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @subscriptions.each do |subscription| %>
              <tr>
                <td><%= subscription.id %></td>
                <td><%= subscription.user.email %></td>
                <td><%= subscription.plan.name %></td>
                <td><span class="badge <%= status_badge_class(subscription.status) %>"><%= subscription.status %></span></td>
                <td><%= subscription.next_due_date %></td>
                <td><%= subscription.closed_at || t(".lifetime") %></td>
                <td><%= link_to "Ver", admin_subscription_path(subscription), class: "btn btn-sm btn-outline-secondary" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
