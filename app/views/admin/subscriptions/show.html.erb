<div class="app-content-header">
  <div class="container-fluid">
    <h3 class="mb-0">Assinatura #<%= @subscription.id %></h3>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <div class="card mb-3">
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-3">Cliente</dt>
          <dd class="col-sm-9"><%= @subscription.user.email %></dd>

          <dt class="col-sm-3">Plano</dt>
          <dd class="col-sm-9"><%= @subscription.plan.name %></dd>

          <dt class="col-sm-3">Status</dt>
          <dd class="col-sm-9"><span class="badge <%= status_badge_class(@subscription.status) %>"><%= @subscription.status %></span></dd>

          <dt class="col-sm-3">Início</dt>
          <dd class="col-sm-9"><%= @subscription.joined_at %></dd>

          <dt class="col-sm-3">Próx. Vencimento</dt>
          <dd class="col-sm-9"><%= @subscription.next_due_date %></dd>

          <dt class="col-sm-3">Encerramento</dt>
          <dd class="col-sm-9"><%= @subscription.closed_at || "Vitalício" %></dd>

          <dt class="col-sm-3">Método de Pagamento</dt>
          <dd class="col-sm-9">
            <% if @subscription.payment_method.present? %>
              <% pm = Shared::PaymentMethods::Registry.find(@subscription.payment_method.to_sym) rescue nil %>
              <%= pm ? pm.new.human_name : @subscription.payment_method %>
            <% else %>
              <span class="text-muted">Não definido</span>
            <% end %>
          </dd>

          <% if @subscription.canceled_at %>
            <dt class="col-sm-3">Cancelado em</dt>
            <dd class="col-sm-9"><%= @subscription.canceled_at %></dd>
          <% end %>

          <% if %w[active error_payment].include?(@subscription.status) && @subscription.closed_at %>
            <dt class="col-sm-3">Valor residual</dt>
            <dd class="col-sm-9"><%= @subscription.residual_value %></dd>
          <% end %>
        </dl>
      </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
      <% if @subscription.valid_transition?("active") %>
        <%= button_to "Ativar", activate_admin_subscription_path(@subscription), method: :patch, class: "btn btn-success" %>
      <% end %>
      <% if @subscription.valid_transition?("error_payment") %>
        <%= button_to "Marcar Erro", fail_admin_subscription_path(@subscription), method: :patch, class: "btn btn-warning" %>
      <% end %>
      <% if @subscription.valid_transition?("pending_payment") %>
        <%= button_to "Tentar Novamente", retry_admin_subscription_path(@subscription), method: :patch, class: "btn btn-info" %>
      <% end %>
      <% if @subscription.valid_transition?("canceled") %>
        <%= button_to "Cancelar", cancel_admin_subscription_path(@subscription), method: :patch, class: "btn btn-danger", data: { turbo_confirm: "Confirmar cancelamento?" } %>
      <% end %>
      <% if @subscription.valid_transition?("closed") %>
        <%= button_to "Encerrar", close_admin_subscription_path(@subscription), method: :patch, class: "btn btn-secondary" %>
      <% end %>
    </div>

    <div class="card mt-3">
      <div class="card-header">Método de Pagamento</div>
      <div class="card-body">
        <%= form_with url: update_payment_method_admin_subscription_path(@subscription), method: :patch do |f| %>
          <div class="d-flex gap-2 align-items-end">
            <div class="flex-grow-1">
              <%= f.select :payment_method,
                  Shared::PaymentMethods::Registry.active_methods.map { |key, klass| [klass.new.human_name, key.to_s] },
                  { selected: @subscription.payment_method },
                  { name: "subscription[payment_method]", class: "form-select" } %>
            </div>
            <%= f.submit "Atualizar", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="mt-3">
      <%= link_to "← Voltar", admin_subscriptions_path, class: "btn btn-outline-secondary" %>
    </div>
  </div>
</div>
