<% content_for :page_title, "Usuário ##{@user.id}" %>

<div class="row">
  <div class="col-md-6">
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">Dados do Usuário</h3>
        <div class="card-tools">
          <%= link_to "Editar", edit_admin_user_path(@user), class: "btn btn-sm btn-warning" %>
          <%= link_to "Voltar", admin_users_path, class: "btn btn-sm btn-secondary" %>
        </div>
      </div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-sm-4">ID</dt>
          <dd class="col-sm-8"><%= @user.id %></dd>

          <dt class="col-sm-4">E-mail</dt>
          <dd class="col-sm-8"><%= @user.email %></dd>

          <dt class="col-sm-4">Nome</dt>
          <dd class="col-sm-8"><%= @user.full_name || "—" %></dd>

          <dt class="col-sm-4">CPF</dt>
          <dd class="col-sm-8"><%= @user.document || "—" %></dd>

          <dt class="col-sm-4">Telefone</dt>
          <dd class="col-sm-8"><%= @user.phone || "—" %></dd>

          <dt class="col-sm-4">Role</dt>
          <dd class="col-sm-8">
            <span class="badge bg-<%= @user.admin? ? 'danger' : 'secondary' %>">
              <%= @user.role %>
            </span>
          </dd>
        </dl>
      </div>
    </div>
  </div>

  <% unless @user == current_user %>
    <div class="col-md-6">
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Alterar Papel (Role)</h3>
        </div>
        <div class="card-body">
          <%= form_with url: update_role_admin_user_path(@user), method: :patch do |f| %>
            <div class="mb-3">
              <%= f.label :role, "Novo papel", class: "form-label" %>
              <%= f.select :role,
                    [["Customer", "customer"], ["Admin", "admin"]],
                    { selected: @user.role },
                    class: "form-select" %>
            </div>
            <%= f.submit "Atualizar Role", class: "btn btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>
