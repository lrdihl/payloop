<div class="app-content-header">
  <div class="container-fluid">
    <h3 class="mb-0"><%= t(".title") %></h3>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <% if policy(User).create? %>
      <%= link_to t(".new"), new_admin_user_path, class: "btn btn-primary mb-3" %>
    <% end %>

    <div class="card">
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th><%= t(".columns.id") %></th>
              <th><%= t(".columns.email") %></th>
              <th><%= t(".columns.name") %></th>
              <th><%= t(".columns.role") %></th>
              <th><%= t(".columns.actions") %></th>
            </tr>
          </thead>
          <tbody>
            <% @users.each do |user| %>
              <tr>
                <td><%= user.id %></td>
                <td><%= user.email %></td>
                <td><%= user.full_name || "—" %></td>
                <td>
                  <span class="badge bg-<%= user.admin? ? 'danger' : 'secondary' %>">
                    <%= user.role %>
                  </span>
                </td>
                <td>
                  <%= link_to "Ver", admin_user_path(user), class: "btn btn-sm btn-outline-info" %>
                  <% if policy(user).update? %>
                    <%= link_to t("shared.actions.edit"), edit_admin_user_path(user), class: "btn btn-sm btn-outline-warning" %>
                  <% end %>
                  <% if policy(user).destroy? %>
                    <%= button_to t("shared.actions.remove"), admin_user_path(user), method: :delete,
                          class: "btn btn-sm btn-outline-danger",
                          data: { turbo_confirm: t("shared.actions.confirm_remove") } %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
