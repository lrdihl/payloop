<% content_for :page_title, "Novo Usuário" %>

<div class="card">
  <div class="card-header">
    <h3 class="card-title">Criar Usuário</h3>
    <div class="card-tools">
      <%= link_to "Voltar", admin_users_path, class: "btn btn-sm btn-secondary" %>
    </div>
  </div>
  <div class="card-body">
    <%= form_with model: [:admin, @user], url: admin_users_path, local: true do |f| %>
      <%= render "form", f: f, new_record: true %>
      <div class="mt-3">
        <%= f.submit "Criar Usuário", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
