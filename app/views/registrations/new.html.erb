<p class="login-box-msg"><%= t("auth.register.title") %></p>

<%= render "shared/errors", errors: @errors %>

<%= form_for(resource, as: resource_name, url: user_registration_path) do |f| %>
  <div class="mb-3">
    <%= f.label :email, t("auth.register.email"), class: "form-label" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "form-control", placeholder: t("auth.register.email_placeholder") %>
  </div>

  <div class="mb-3">
    <%= f.label :password, t("auth.register.password"), class: "form-label" %>
    <%= f.password_field :password, autocomplete: "new-password",
          class: "form-control", placeholder: t("auth.register.password_placeholder") %>
  </div>

  <div class="mb-3">
    <%= f.label :password_confirmation, t("auth.register.password_confirmation"), class: "form-label" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
          class: "form-control", placeholder: t("auth.register.password_confirmation_placeholder") %>
  </div>

  <hr class="my-3">
  <p class="text-muted small mb-2"><%= t("auth.register.profile_section") %></p>

  <%= f.fields_for :profile_attributes, Profile.new do |pf| %>
    <div class="mb-3">
      <%= pf.label :full_name, t("auth.register.full_name"), class: "form-label" %>
      <%= pf.text_field :full_name, class: "form-control", placeholder: t("auth.register.full_name_placeholder") %>
    </div>

    <div class="mb-3">
      <%= pf.label :document, t("auth.register.document"), class: "form-label" %>
      <%= pf.text_field :document, class: "form-control", placeholder: t("auth.register.document_placeholder") %>
    </div>

    <div class="mb-3">
      <%= pf.label :phone, t("auth.register.phone"), class: "form-label" %>
      <%= pf.text_field :phone, class: "form-control", placeholder: t("auth.register.phone_placeholder") %>
    </div>
  <% end %>

  <div class="d-grid">
    <%= f.submit t("auth.register.submit"), class: "btn btn-primary" %>
  </div>
<% end %>

<p class="mt-3 text-center">
  <%= t("auth.register.already_have_account") %> <%= link_to t("auth.register.sign_in_link"), new_user_session_path %>
</p>
