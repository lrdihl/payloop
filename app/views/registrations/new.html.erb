<p class="login-box-msg">Crie sua conta no Payloop</p>

<%= render "shared/errors", errors: @errors %>

<%= form_for(resource, as: resource_name, url: user_registration_path) do |f| %>
  <div class="mb-3">
    <%= f.label :email, "E-mail", class: "form-label" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "form-control", placeholder: "seu@email.com" %>
  </div>

  <div class="mb-3">
    <%= f.label :password, "Senha", class: "form-label" %>
    <%= f.password_field :password, autocomplete: "new-password",
          class: "form-control", placeholder: "Mínimo 6 caracteres" %>
  </div>

  <div class="mb-3">
    <%= f.label :password_confirmation, "Confirmar Senha", class: "form-label" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
          class: "form-control", placeholder: "Repita a senha" %>
  </div>

  <hr class="my-3">
  <p class="text-muted small mb-2">Dados do perfil</p>

  <%= f.fields_for :profile_attributes, Profile.new do |pf| %>
    <div class="mb-3">
      <%= pf.label :full_name, "Nome completo", class: "form-label" %>
      <%= pf.text_field :full_name, class: "form-control", placeholder: "Maria da Silva" %>
    </div>

    <div class="mb-3">
      <%= pf.label :document, "CPF", class: "form-label" %>
      <%= pf.text_field :document, class: "form-control", placeholder: "00000000000" %>
    </div>

    <div class="mb-3">
      <%= pf.label :phone, "Telefone", class: "form-label" %>
      <%= pf.text_field :phone, class: "form-control", placeholder: "47999999999" %>
    </div>
  <% end %>

  <div class="d-grid">
    <%= f.submit "Criar conta", class: "btn btn-primary" %>
  </div>
<% end %>

<p class="mt-3 text-center">
  Já tem conta? <%= link_to "Entrar", new_user_session_path %>
</p>
