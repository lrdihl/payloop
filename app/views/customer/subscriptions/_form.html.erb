<%= render "shared/errors", errors: @errors if @errors %>

<%= form_with url: customer_subscriptions_path, method: :post do |f| %>
  <div class="mb-3">
    <%= f.label :plan_id, t("customer.subscriptions.form.plan"), class: "form-label" %>
    <%= f.select :plan_id,
        Plan.kept.active.order(:name).map { |p| ["#{p.name} — #{number_to_currency(p.price_cents.to_f / 100, unit: 'R$', separator: ',', delimiter: '.')}", p.id] },
        { include_blank: t("customer.subscriptions.form.plan_blank") },
        { name: "subscription[plan_id]", class: "form-select" } %>
  </div>

  <div class="mb-3">
    <%= f.label :payment_method, t("customer.subscriptions.form.payment_method"), class: "form-label" %>
    <%= f.select :payment_method,
        Shared::PaymentMethods::Registry.selectable_methods.map { |key, klass| [klass.new.human_name, key.to_s] },
        { include_blank: t("customer.subscriptions.form.payment_method_blank") },
        { name: "subscription[payment_method]", class: "form-select" } %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit t("customer.subscriptions.form.submit"), class: "btn btn-primary" %>
    <%= link_to t("shared.actions.cancel"), customer_subscriptions_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
