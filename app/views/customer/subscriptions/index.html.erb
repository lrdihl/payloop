<div class="app-content-header">
  <div class="container-fluid">
    <h3 class="mb-0"><%= t(".title") %></h3>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <% unless Subscription.current.exists?(user_id: current_user.id) %>
      <%= link_to t(".new"), new_customer_subscription_path, class: "btn btn-primary mb-3" %>
    <% end %>

    <div class="card">
      <div class="card-body p-0">
        <% if @subscriptions.any? %>
          <table class="table table-striped mb-0">
            <thead>
              <tr>
                <th><%= t(".columns.plan") %></th>
                <th><%= t(".columns.status") %></th>
                <th><%= t(".columns.payment_method") %></th>
                <th><%= t(".columns.joined_at") %></th>
                <th><%= t(".columns.next_due") %></th>
                <th><%= t(".columns.closed_at") %></th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% @subscriptions.each do |subscription| %>
                <tr>
                  <td><%= subscription.plan.name %></td>
                  <td><span class="badge <%= status_badge_class(subscription.status) %>"><%= subscription.status %></span></td>
                  <td>
                    <% if policy(subscription).update_payment_method? %>
                      <%= form_with url: update_payment_method_customer_subscription_path(subscription), method: :patch, class: "d-flex gap-1" do |f| %>
                        <%= f.select :payment_method,
                            Shared::PaymentMethods::Registry.active_methods.map { |key, klass| [klass.new.human_name, key.to_s] },
                            { selected: subscription.payment_method },
                            { name: "subscription[payment_method]", class: "form-select form-select-sm" } %>
                        <%= f.submit "OK", class: "btn btn-sm btn-outline-primary" %>
                      <% end %>
                    <% else %>
                      <% pm = Shared::PaymentMethods::Registry.find(subscription.payment_method.to_sym) rescue nil %>
                      <%= pm ? pm.new.human_name : (subscription.payment_method || "—") %>
                    <% end %>
                  </td>
                  <td><%= subscription.joined_at %></td>
                  <td><%= subscription.next_due_date %></td>
                  <td><%= subscription.closed_at || t(".lifetime") %></td>
                  <td>
                    <% if subscription.status == "active" %>
                      <%= button_to t(".cancel_button"), cancel_customer_subscription_path(subscription),
                          method: :patch,
                          class: "btn btn-sm btn-danger",
                          data: { turbo_confirm: t("shared.actions.confirm_cancel") } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="p-4 text-center text-muted">
            <p><%= t(".empty") %></p>
            <%= link_to t(".subscribe_link"), new_customer_subscription_path, class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
