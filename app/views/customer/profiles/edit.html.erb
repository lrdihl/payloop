<div class="app-content-header">
  <div class="container-fluid">
    <h3 class="mb-0"><%= t(".title") %></h3>
  </div>
</div>

<div class="app-content">
  <div class="container-fluid">
    <div class="card">
      <div class="card-body">
        <%= render "shared/errors", errors: @errors if @errors %>

        <%= form_with url: customer_profile_path, method: :patch do |f| %>
          <div class="mb-3">
            <%= label_tag :full_name, t("customer.profiles.form.full_name"), class: "form-label" %>
            <%= text_field_tag "profile[full_name]", @user.full_name, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= label_tag :document, t("customer.profiles.form.document"), class: "form-label" %>
            <%= text_field_tag "profile[document]", @user.document, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= label_tag :phone, t("customer.profiles.form.phone"), class: "form-label" %>
            <%= text_field_tag "profile[phone]", @user.phone, class: "form-control" %>
          </div>

          <div class="d-flex gap-2">
            <%= submit_tag t("customer.profiles.form.submit"), class: "btn btn-primary" %>
            <%= link_to t("shared.actions.cancel"), customer_profile_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
